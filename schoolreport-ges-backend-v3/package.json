{
  "name": "schoolreport-ges-backend",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "gateway",
    "services/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:gateway\" \"npm run dev:auth\" \"npm run dev:school\" \"npm run dev:students\" \"npm run dev:reports\"",
    "dev:gateway":  "npm run dev --workspace=gateway",
    "dev:auth":     "npm run dev --workspace=services/auth",
    "dev:school":   "npm run dev --workspace=services/school",
    "dev:students": "npm run dev --workspace=services/students",
    "dev:reports":  "npm run dev --workspace=services/reports"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
